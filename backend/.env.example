DB_MUNI_HOST=localhost
DB_MUNI_PORT=3306
DB_MUNI_NAME=muni_sembremos_seguridad
DB_MUNI_USER=root
DB_MUNI_PASSWORD=

DB_MSP_HOST=localhost
DB_MSP_PORT=3306
DB_MSP_NAME=msp_sembremos_seguridad
DB_MSP_USER=root
DB_MSP_PASSWORD=

NODE_ENV=development
JWT_SECRET=
JWT_EXPIRES_IN=1h

# ---- Recordatorios / correo ----
APP_TIMEZONE=America/Costa_Rica
APP_FRONTEND_URL=http://localhost:5173
ENABLE_REMINDERS=true

# SMTP transaccional. Recomendado: Resend (smtp.resend.com, user='resend',
# pass=API key). También funciona Gmail App Password, SendGrid, Mailgun, etc.
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=resend
MAIL_PASS=
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=Sembremos Seguridad

# Solo dev: redirige todos los correos a una sola dirección (ignora to/bcc).
# Necesario con free tier de Resend sin dominio verificado.
MAIL_FORCE_TO=

# Alternativa más suave a MAIL_FORCE_TO: solo agrega BCC silencioso sin cambiar TO.
MAIL_BCC_DEV=

# Google Calendar API (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
