{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:setup": "node create_dbs.js",
    "db:sync": "node sync.js",
    "migrate:msp": "sequelize-cli db:migrate --env msp --migrations-path src/migrations/msp",
    "migrate:muni": "sequelize-cli db:migrate --env muni --migrations-path src/migrations/muni",
    "migrate:undo:msp": "sequelize-cli db:migrate:undo --env msp --migrations-path src/migrations/msp",
    "migrate:undo:muni": "sequelize-cli db:migrate:undo --env muni --migrations-path src/migrations/muni",
    "migrate:undo:all:msp": "sequelize-cli db:migrate:undo:all --env msp --migrations-path src/migrations/msp",
    "migrate:undo:all:muni": "sequelize-cli db:migrate:undo:all --env muni --migrations-path src/migrations/muni",
    "seed:msp": "sequelize-cli db:seed:all --env msp --seeders-path src/seeders/msp",
    "seed:muni": "sequelize-cli db:seed:all --env muni --seeders-path src/seeders/muni",
    "seed:undo:msp": "sequelize-cli db:seed:undo:all --env msp --seeders-path src/seeders/msp",
    "seed:undo:muni": "sequelize-cli db:seed:undo:all --env muni --seeders-path src/seeders/muni",
    "seed:all": "npm run seed:msp && npm run seed:muni",
    "seed:undo": "npm run seed:undo:msp && npm run seed:undo:muni"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.2.0",
    "ics": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  }
}
