            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Prueba\",\n  \"apellido\": \"Postman\",\n  \"cedula\": \"102340567\",\n  \"email\": \"prueba.postman+{{$timestamp}}@test.com\",\n  \"password\": \"Test1234!\",\n  \"nivel\": \"MUNI\",\n  \"role\": \"GESTOR_MUNI\",\n  \"institucion_id\": 1\n}"
            },
