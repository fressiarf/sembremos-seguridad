            "body": { "mode": "raw", "raw": "{\n  \"password\": \"Test1234!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/system/auth/test-hash", "host": ["{{baseUrl}}"], "path": ["api", "v1", "system", "auth", "test-hash"] },
            "description": "Sólo ADMIN_MSP. Asegurate de loguearte primero con un usuario admin."
          },
          "event": [
