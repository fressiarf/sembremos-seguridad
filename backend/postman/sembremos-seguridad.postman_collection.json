            }
          ]
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] },
            "description": "Devuelve el usuario actual a partir de la cookie `token`. Requiere haber ejecutado un login antes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Trae user', () => pm.expect(body.data.user).to.have.property('email'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me (sin cookie → 401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "token=" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] },
            "description": "Forzamos cookie vacía para asegurar el 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
